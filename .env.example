NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
ANTHROPIC_API_KEY=sk-ant-...

# Optional, only for the manual Tier 2 enrichment step (src/enrich_tier2.py).
# From a logged-in Creative Center browser session -- these expire in ~3 days,
# so they're not used by the daily cron. Leave blank unless running Tier 2.
TIKTOK_COOKIE=
TIKTOK_CSRF=

# Optional, for Tier 3 (real TikTok Shop products + sales signal) via EchoTik's
# data API. Sign up at echotik.live, generate an API key in the dashboard.
ECHOTIK_API_KEY=
